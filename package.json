{
  "name": "pylon",
  "desktopName": "app.pylon.client.desktop",
  "version": "0.0.5",
  "description": "A desktop client for voice, video/screen-share, and text chat.",
  "main": "./out/main/index.js",
  "author": "Phloxin",
  "homepage": "https://github.com/Phloxin/client",
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=10"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:native": "npm --prefix native/audio-capture run build",
    "postinstall": "node scripts/postinstall.cjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource-variable/roboto": "^5.2.10",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@tabler/icons-react": "^3.44.0",
    "audio-capture": "file:native/audio-capture",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "mediasoup-client": "^3.20.0",
    "motion": "^12.42.2",
    "react-router-dom": "^7.16.0",
    "simple-markdown": "^0.7.3",
    "uiohook-napi": "^1.5.5",
    "unicode-emoji-json": "^0.9.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "uiohook-napi@1.5.5": true,
    "electron-winstaller": false
  }
}
