# Copy this file to .env.development (and/or .env.production) and adjust as needed.
# .env.* files are gitignored except this template.

# When 'true', the app skips login and the real API/WebSocket connections,
# using mock data from src/renderer/src/lib/mock.js instead.
VITE_DEV_MODE=false

# ─────────────────────────────────────────────────────────────────────────
# Planned (not yet wired up — see roadmap workstream A1):
#   VITE_API_BASE_URL   — absolute API origin for production builds
#   VITE_WS_BASE_URL    — absolute WebSocket origin for production builds
#   VITE_TURN_URL       — TURN server URL
#   VITE_TURN_USERNAME  — TURN server username
#   VITE_TURN_CREDENTIAL — TURN server credential
# ─────────────────────────────────────────────────────────────────────────
